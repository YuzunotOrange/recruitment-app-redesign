APP_NAME=Recruitment App API
ENVIRONMENT=development
DATABASE_URL=sqlite:///./app.db
FRONTEND_ORIGIN=http://localhost:3000
# Local development can omit JWT_SECRET_KEY.
# For production/staging, set a long random secret and never commit it.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Render sets PORT automatically. Local Docker defaults to 8000 if omitted.
PORT=8000

# Deadline/interview reminder emails. Leave SMTP_HOST unset to disable email
# sending entirely — reminders will still appear in-app either way.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=CareerTrack <no-reply@example.com>
# SMTP_USE_TLS=true
# REMINDER_EMAIL_INTERVAL_MINUTES=30

# Web push (VAPID). A key pair is auto-generated at this path on first use.
# Point it at a persistent location in production so subscriptions survive deploys.
# VAPID_PRIVATE_KEY_FILE=./vapid_private.pem
# VAPID_SUBJECT=mailto:admin@example.com

# Production example:
# ENVIRONMENT=production
# DATABASE_URL=postgresql://user:password@your-rds-endpoint:5432/recruitment_app
# FRONTEND_ORIGIN=https://your-frontend-domain.example.com
# JWT_SECRET_KEY=replace-with-a-long-random-secret
# PORT is usually provided by the hosting platform.

# Supabase example:
# DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres?sslmode=require
