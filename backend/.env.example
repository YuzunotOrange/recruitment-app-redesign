APP_NAME=Recruitment App API
ENVIRONMENT=development
DATABASE_URL=sqlite:///./app.db
FRONTEND_ORIGIN=http://localhost:3000
# Local development can omit JWT_SECRET_KEY.
# For production/staging, set a long random secret and never commit it.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production example:
# ENVIRONMENT=production
# DATABASE_URL=postgresql://user:password@your-rds-endpoint:5432/recruitment_app
# FRONTEND_ORIGIN=https://your-frontend-domain.example.com
# JWT_SECRET_KEY=replace-with-a-long-random-secret
